# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# data pipeline sources (operator-supplied; see data/README.md)
/data/JMdict_e.gz
/data/sentence_pairs.tsv
/data/grammar.zip
/data/kanjidic2.xml.gz
# kradzip is the EDRDG archive; the contained radical files (radkfile{,-u,2,x},
# kradfile{,2}) all get extracted into data/ depending on which variant the
# operator picks.
/data/kradzip.zip
/data/radkfile
/data/radkfile-u
/data/radkfile2
/data/radkfilex
/data/kradfile
/data/kradfile2

# v1 snapshot — kept locally for reference, not redistributed
/archive/

# data pipeline scratch + generated outputs
/.pipeline-work/
/.handwriting-work/
# Most of /public/data/ is gitignored (large, rebuild-able, fetchable via
# `npm run data:fetch`). The small kanji-tab assets are tracked exceptions
# so a fresh clone has everything the Kanji screen needs after npm install
# alone — they're independently rebuild-able via the Python data pipeline
# (or tools/handwriting_ocr for the recognizer) and refresh rarely.
#   * kanji-recognizer.onnx (2.9 MB)  — handwriting INT8 model, ~1h GPU rebuild
#   * kanji-classes.json    (33 KB)   — paired class index for the model
#   * kanji.json.gz         (220 KB)  — Stage 7: per-kanji metadata
#   * radkfile.json.gz      (68 KB)   — Stage 7: radical → kanji bitsets
/public/data/*
!/public/data/kanji-recognizer.onnx
!/public/data/kanji-classes.json
!/public/data/kanji.json.gz
!/public/data/radkfile.json.gz
/venv/
__pycache__/
*.pyc

# kuromoji IPADIC dict synced from node_modules by postinstall
/public/dict/

# onnxruntime-web WASM artifacts synced from node_modules by postinstall
/public/onnx/

# terraform state and local plan caches (real state should live in a remote backend)
/terraform/.terraform/
/terraform/*.tfstate
/terraform/*.tfstate.*
/terraform/*.tfplan
/terraform/.terraform.tfstate.lock.info
