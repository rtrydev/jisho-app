{
  "name": "jisho-app",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/fingerprint-recognizer.mjs && node scripts/fingerprint-segmenter.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "data:fetch": "node scripts/fetch-prebuilt-data.mjs",
    "postinstall": "node scripts/sync-kuromoji-dict.mjs && node scripts/sync-onnx-runtime.mjs && node scripts/fingerprint-recognizer.mjs && node scripts/fingerprint-segmenter.mjs"
  },
  "dependencies": {
    "kuromoji": "^0.1.2",
    "next": "16.2.6",
    "onnxruntime-web": "^1.26.0",
    "pako": "^2.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^20",
    "@types/pako": "^2.0.4",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/coverage-v8": "^4.1.6",
    "eslint": "^9",
    "eslint-config-next": "16.2.6",
    "jsdom": "^29.1.1",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.6"
  }
